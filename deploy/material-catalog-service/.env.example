MATERIAL_CATALOG_PORT=8091
MATERIAL_CATALOG_ALLOWED_ROOTS=storage,.
MATERIAL_CATALOG_SYNC_INTERVAL_SECONDS=3600
MATERIAL_CATALOG_MAX_HASH_BYTES=536870912
MATERIAL_CATALOG_MEDIA_CACHE_DIR=/app/catalog/media-cache
MATERIAL_CATALOG_THUMBNAIL_PUBLIC_PREFIX=/material-agent/media
MATERIAL_CATALOG_THUMBNAIL_DEFAULT_WIDTH=1024
MATERIAL_CATALOG_THUMBNAIL_DEFAULT_QUALITY=78
MATERIAL_CATALOG_THUMBNAIL_MAX_WIDTH=2048
DIFY_APP_VOLUME_HOST=/opt/mmb-dify/current/docker/volumes/app
DIFY_DOCKER_NETWORK=mmb-dify-v010_default
DIFY_DB_HOST=db_postgres
DIFY_DB_PORT=5432
DIFY_DB_NAME=dify
DIFY_DB_USER=postgres
DIFY_DB_PASSWORD=
# Optional but recommended for image rendering in Dify chat. Use the same SECRET_KEY as the Dify API container.
DIFY_FILES_URL=
DIFY_FILE_PREVIEW_SECRET_KEY=
DIFY_FILE_PREVIEW_TTL_SECONDS=300
