# Copy to .env on T1000 and fill real secrets there. Do not commit .env.

# OpenWebUI listens on this host port. 80/443 are used by Dify nginx and 3000 is used by tradingagents.
OPENWEBUI_PORT=8088

# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
WEBUI_SECRET_KEY=replace-with-generated-secret

# Keep signup enabled so the first admin account can be created from the UI.
# New users remain pending because DEFAULT_USER_ROLE is set in docker-compose.yaml.
ENABLE_SIGNUP=true

# Optional: connect an OpenAI-compatible Dify App endpoint after installing the Dify plugin.
# Multiple endpoints/keys are separated by semicolons.
# OPENAI_API_BASE_URLS=http://docker-nginx-1/v1
# OPENAI_API_KEYS=app-xxxxxxxxxxxxxxxxxxxxxxxx