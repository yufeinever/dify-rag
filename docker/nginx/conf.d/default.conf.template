# Please do not directly edit this file. Instead, modify the .env variables related to NGINX configuration.

server {
    listen ${NGINX_PORT};
    server_name ${NGINX_SERVER_NAME};

    location = /custom-assets/mmb-logo/signin-logo-patch.js {
      proxy_pass http://web:3000;
      include proxy.conf;
      add_header Cache-Control "no-store, no-cache, must-revalidate, max-age=0" always;
    }

    location = /custom-assets/mmb-logo/global-brand-patch.js {
      proxy_pass http://web:3000;
      include proxy.conf;
      add_header Cache-Control "no-store, no-cache, must-revalidate, max-age=0" always;
    }

    location /console/api {
      proxy_pass http://api:5001;
      include proxy.conf;
    }

    location /api {
      proxy_pass http://api:5001;
      include proxy.conf;
    }

    location /socket.io/ {
      resolver 127.0.0.11 valid=30s ipv6=off;
      set $socket_io_upstream ${NGINX_SOCKET_IO_UPSTREAM};
      proxy_pass http://$socket_io_upstream;
      include proxy.conf;
      proxy_set_header Upgrade $http_upgrade;
      proxy_set_header Connection "upgrade";
      proxy_cache_bypass $http_upgrade;
    }

    location /v1 {
      proxy_pass http://api:5001;
      include proxy.conf;
    }

    location /files {
      proxy_pass http://api:5001;
      include proxy.conf;
    }

    location /web-apps/ {
      proxy_pass http://onlyoffice;
      include proxy.conf;
      proxy_set_header X-Forwarded-Host $host;
    }

    location /sdkjs/ {
      proxy_pass http://onlyoffice;
      include proxy.conf;
      proxy_set_header X-Forwarded-Host $host;
    }

    location /cache/ {
      proxy_pass http://onlyoffice;
      include proxy.conf;
      proxy_set_header X-Forwarded-Host $host;
    }

    location /doc/ {
      proxy_pass http://onlyoffice;
      include proxy.conf;
      proxy_set_header X-Forwarded-Host $host;
    }

    location /coauthoring/ {
      proxy_pass http://onlyoffice;
      include proxy.conf;
      proxy_set_header X-Forwarded-Host $host;
      proxy_set_header Upgrade $http_upgrade;
      proxy_set_header Connection "upgrade";
    }

    location /spellchecker/ {
      proxy_pass http://onlyoffice;
      include proxy.conf;
      proxy_set_header X-Forwarded-Host $host;
    }

    location /explore {
      proxy_pass http://web:3000;
      include proxy.conf;
      proxy_set_header Accept-Encoding "";
      sub_filter_once off;
      sub_filter_types text/html;
      sub_filter '</body>' '<script defer src="/custom-assets/mmb-logo/global-brand-patch.js?v=20260624-4"></script></body>';
    }

    location /e/ {
      proxy_pass http://plugin_daemon:5002;
      proxy_set_header Dify-Hook-Url $scheme://$host$request_uri;
      include proxy.conf;
    }

    location = /signin {
      proxy_pass http://web:3000;
      include proxy.conf;
      proxy_set_header Accept-Encoding "";
      sub_filter_once off;
      sub_filter_types text/html;
      sub_filter '</body>' '<script defer src="/custom-assets/mmb-logo/signin-logo-patch.js?v=20260624-11"></script></body>';
    }

    location / {
      proxy_pass http://web:3000;
      include proxy.conf;
      proxy_set_header Accept-Encoding "";
      sub_filter_once off;
      sub_filter_types text/html;
      sub_filter '</body>' '<script defer src="/custom-assets/mmb-logo/global-brand-patch.js?v=20260624-4"></script></body>';
    }

    location /mcp {
      proxy_pass http://api:5001;
      include proxy.conf;
    }

    location /triggers {
      proxy_pass http://api:5001;
      include proxy.conf;
    }
    
    # placeholder for acme challenge location
    ${ACME_CHALLENGE_LOCATION}

    # placeholder for https config defined in https.conf.template
    ${HTTPS_CONFIG}
}
